<?xml version="1.0" encoding="UTF-8"?>
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<events>
    <event>
        <uei>uei.example.org/test/testTrap</uei>
        <event-label>BASIC-TEST-MIB defined trap event: testTrap</event-label>
        <descr>
&lt;p&gt;A basic test trap&lt;/p&gt;&lt;table&gt;
	&lt;tr&gt;&lt;td&gt;&lt;b&gt;

	testString&lt;/b&gt;&lt;/td&gt;&lt;td&gt;
	%parm[#1]%;&lt;/td&gt;&lt;td&gt;&lt;p&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;
	&lt;tr&gt;&lt;td&gt;&lt;b&gt;

	testCounter&lt;/b&gt;&lt;/td&gt;&lt;td&gt;
	%parm[#2]%;&lt;/td&gt;&lt;td&gt;&lt;p&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;
	</descr>
        <logmsg dest="logndisplay">&lt;p&gt;
	testTrap trap received
	testString=%parm[#1]%
	testCounter=%parm[#2]%&lt;/p&gt;
	</logmsg>
        <severity>Indeterminate</severity>
        <mask>
            <maskelement>
                <mename>id</mename>
                <mevalue>.1.3.6.1.4.1.99999</mevalue>
            </maskelement>
            <maskelement>
                <mename>generic</mename>
                <mevalue>6</mevalue>
            </maskelement>
            <maskelement>
                <mename>specific</mename>
                <mevalue>1</mevalue>
            </maskelement>
        </mask>
    </event>
    <event>
        <uei>uei.example.org/test/testTrap2</uei>
        <event-label>BASIC-TEST-MIB defined trap event: testTrap2</event-label>
        <descr>
&lt;p&gt;Another test trap&lt;/p&gt;&lt;table&gt;
	&lt;tr&gt;&lt;td&gt;&lt;b&gt;

	testString&lt;/b&gt;&lt;/td&gt;&lt;td&gt;
	%parm[#1]%;&lt;/td&gt;&lt;td&gt;&lt;p&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;
	</descr>
        <logmsg dest="logndisplay">&lt;p&gt;
	testTrap2 trap received
	testString=%parm[#1]%&lt;/p&gt;
	</logmsg>
        <severity>Indeterminate</severity>
        <mask>
            <maskelement>
                <mename>id</mename>
                <mevalue>.1.3.6.1.4.1.99999</mevalue>
            </maskelement>
            <maskelement>
                <mename>generic</mename>
                <mevalue>6</mevalue>
            </maskelement>
            <maskelement>
                <mename>specific</mename>
                <mevalue>2</mevalue>
            </maskelement>
        </mask>
    </event>
</events>
